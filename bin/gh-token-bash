#!/bin/bash
set -o pipefail
# --------------------------------------------------------------------
# A bash implementation of "gh-token" to generate a GitHub App token
# without requiring the gh-token CLI tool.
# Ref: https://docs.github.com/en/apps/creating-github-apps/authenticating-with-a-github-app/generating-a-json-web-token-jwt-for-a-github-app
# Usage:
#   ./gh-token-bash <app_id> <install_id> <key>
# --------------------------------------------------------------------

GH_APP_ID="${1:?Usage: ${BASH_SOURCE[0]} <app_id> <install_id> <key>}"
GH_APP_INSTALL_ID="${2:?Usage: ${BASH_SOURCE[0]} <app_id> <install_id> <key>}"
GH_APP_KEY="${3:?Usage: ${BASH_SOURCE[0]} <app_id> <install_id> <key>}"

now=$(date +%s)
iat=$((now - 60)) # Issues 60 seconds in the past
exp=$((now + 600)) # Expires 10 minutes in the future

b64enc() { openssl base64 | tr -d '=' | tr '/+' '_-' | tr -d '\n'; }

header_json='{
    "typ":"JWT",
    "alg":"RS256"
}'
# Header encode
header=$( echo -n "${header_json}" | b64enc )

payload_json="{
    \"iat\":${iat},
    \"exp\":${exp},
    \"iss\":\"${GH_APP_ID}\"
}"
# Payload encode
payload=$( echo -n "${payload_json}" | b64enc )

# Signature
header_payload="${header}"."${payload}"
signature=$(
    openssl dgst -sha256 -sign <(echo -n "$(cat "${GH_APP_KEY}")") \
    <(echo -n "${header_payload}") | b64enc
)

# Create JWT
JWT="${header_payload}"."${signature}"

# Exchange JWT for an installation access token
curl -sf -X POST \
    -H "Authorization: Bearer $JWT" \
    -H "Accept: application/vnd.github+json" \
    "https://api.github.com/app/installations/$GH_APP_INSTALL_ID/access_tokens" \
    | jq -r '.token'
